#!/bin/bash
#SBATCH --job-name=phosp_md
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task={{ resources.ntasks }}
#SBATCH --gres=gpu:{{ resources.gpus }}
#SBATCH --time={{ resources.walltime }}
#SBATCH --partition={{ resources.partition }}
#SBATCH --output={{ output_dir }}/slurm_%j.out
#SBATCH --error={{ output_dir }}/slurm_%j.err
{% for directive in resources.extra_directives %}
#SBATCH {{ directive }}
{% endfor %}

{% if resources.gromacs_module %}
module load {{ resources.gromacs_module }}
{% else %}
# Set hpc.gromacs_module in your phosp config to load the GROMACS environment module.
{% endif %}

set -euo pipefail
# Resolve WORK from this script's own location rather than hardcoding
# {{ output_dir }} — the pipeline may still be renaming the tmp stage
# directory to its final name when a fast scheduler dispatches this job,
# so a baked-in path can point at a directory that doesn't exist yet.
# This script's containing directory is correct at whatever moment it
# actually runs, tmp or final.
WORK="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
cd "$WORK"

{% set is_mpi = '_mpi' in binary %}
{# On SLURM/PBS the scheduler assigns the actual GPU device at submit time, so
   a config can legitimately request a GPU (hpc.gpus > 0) without knowing
   gpu_id in advance — offload must still turn on in that case, not only when
   gpu_id is explicitly set. -gpu_id itself is only emitted when known. #}
{% set use_gpu = (resources.gpus and resources.gpus > 0) or (gpu_id is not none) %}
{% for phase in phases %}
echo "=== Running {{ phase }} ==="

{# GPU-resident update (-update gpu) requires a dynamical integrator
   (md/md-vv/sd); minimization uses steep and GROMACS fatal-errors if
   -update gpu is passed to it. -nb/-pme/-bonded gpu are pure per-step
   force-calculation offloads, independent of the integrator, so they're
   valid (and desirable) for minimization too — see engines/gromacs.py's
   local mdrun path, which this must match. #}
{% set use_update_gpu = use_gpu and phase != 'minimization' %}
{{ binary }} grompp \
    -f ../stage2/{{ phase }}.mdp \
    -c {% if loop.first %}../stage2/ions.gro{% else %}{{ loop.previtem }}/{{ loop.previtem }}.gro{% endif %} \
    -p ../stage2/topol.top \
    -o {{ phase }}/{{ phase }}.tpr \
    {% if phase in ['nvt', 'npt'] %}-r ../stage2/ions.gro {% endif %}-maxwarn 2

{% if is_mpi %}
srun -n 1 --cpus-per-task=$SLURM_CPUS_PER_TASK \
    {{ binary }} mdrun -v -deffnm {{ phase }}/{{ phase }} \
    -ntomp $SLURM_CPUS_PER_TASK \
    {% if gpu_id is not none %}-gpu_id {{ gpu_id }} {% endif %}{% if use_gpu %}-nb gpu -pme gpu -bonded gpu {% endif %}{% if use_update_gpu %}-update gpu{% endif %}

{% else %}
{{ binary }} mdrun -v -deffnm {{ phase }}/{{ phase }} \
    -ntmpi 1 -ntomp $SLURM_CPUS_PER_TASK \
    {% if gpu_id is not none %}-gpu_id {{ gpu_id }} {% endif %}{% if use_gpu %}-nb gpu -pme gpu -bonded gpu {% endif %}{% if use_update_gpu %}-update gpu{% endif %}

{% endif %}
{% endfor %}
