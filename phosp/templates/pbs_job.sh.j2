#!/bin/bash
#PBS -N phosp
#PBS -l nodes=1:ppn={{ resources.ntasks }}:gpus={{ resources.gpus }}
#PBS -l walltime={{ resources.walltime }}
#PBS -q {{ resources.partition }}
#PBS -o {{ output_dir }}/pbs.out
#PBS -e {{ output_dir }}/pbs.err
{% for directive in resources.extra_directives %}
#PBS {{ directive }}
{% endfor %}

{% if resources.gromacs_module %}
module load {{ resources.gromacs_module }}
{% else %}
# Set hpc.gromacs_module in your phosp config to load the GROMACS environment module.
{% endif %}

set -euo pipefail
WORK={{ output_dir }}
cd "$WORK"

{% for phase in phases %}
echo "=== Running {{ phase }} ==="
{{ binary }} grompp -f ../stage2/{{ phase }}.mdp \
    -c {% if loop.first %}../stage2/ions.gro{% else %}{{ loop.previtem }}/{{ loop.previtem }}.gro{% endif %} \
    -p ../stage2/topol.top -o {{ phase }}/{{ phase }}.tpr -maxwarn 2
{{ binary }} mdrun -v -deffnm {{ phase }}/{{ phase }} -ntmpi 1 -ntomp {{ resources.ntasks }} -gpu_id 0
{% endfor %}
